{
  "version": 2,
  "builds": [
    {
      "src": "frontend/package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    },
    {
      "src": "backend/index.ts",
      "use": "@vercel/node@3.0.0"
    }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "backend/index.ts" },
    { "src": "/(.*)", "dest": "frontend/dist/$1" }
  ]
}